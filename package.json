{
  "name": "paid-media-locker",
  "version": "1.0.0",
  "description": "Paid Media Locker - Secure media sharing with immutable transaction records",
  "type": "module",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "test": "jest --coverage",
